---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import homepagePhoto from '../assets/homepage.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.home-photo {
				display: block;
				width: 100%;
				height: auto;
				margin: 0.75rem 0 1.25rem;
				border-radius: 12px;
				box-shadow: var(--box-shadow);
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<section aria-label="Introduction">
				<h1>Hi, I'm Ediz! 👋</h1>
								<p>
					I’m a postdoctoral researcher working in nanophotonics. Here, I share technical blog posts,
					coding projects, and other resources connected to my professional work.
				</p>
				<p>
					I created it as a simple place to collect and share my professional projects. You can learn more about me through the social links below. Feel free to explore.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
