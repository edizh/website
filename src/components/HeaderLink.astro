---
import type { HTMLAttributes } from 'astro/types';
import { publicSiteRoot } from '../lib/siteUrl';

type Props = HTMLAttributes<'a'>;

const { href, class: className, ...props } = Astro.props;

function stripTrailingSlash(p: string) {
	if (p.length > 1 && p.endsWith('/')) return p.slice(0, -1);
	return p;
}

const root = publicSiteRoot(Astro.site);
const here = stripTrailingSlash(Astro.url.pathname);
const target = stripTrailingSlash(
	typeof href === 'string' ? new URL(href, Astro.site).pathname : '',
);
const blogRoot = stripTrailingSlash(new URL('blog/', root).pathname);
const courseRoot = stripTrailingSlash(new URL('course/', root).pathname);

const isActive =
	here === target ||
	(target === blogRoot && (here === blogRoot || here.startsWith(`${blogRoot}/`))) ||
	(target === courseRoot && (here === courseRoot || here.startsWith(`${courseRoot}/`)));
---

<a href={href} class:list={[className, { active: isActive }]} {...props}>
	<slot />
</a>
<style>
	a {
		display: inline-block;
		text-decoration: none;
	}
	a.active {
		font-weight: bolder;
		text-decoration: underline;
	}
</style>
