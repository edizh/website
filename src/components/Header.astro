---
import { FULL_NAME } from '../consts';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';

const base = import.meta.env.BASE_URL;
---

<header>
	<nav>
		<h2><a href={base}>{FULL_NAME}</a></h2>
		<div class="internal-links">
			<HeaderLink href={base}>Home</HeaderLink>
			<HeaderLink href={`${base}blog/`}>Blog</HeaderLink>
			<HeaderLink href={`${base}course/`}>Course</HeaderLink>
		</div>
		<SocialLinks />
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	/* Social links live in <SocialLinks />; scope requires :global so `nav a` rules still apply. */
	:global(nav .social-links a) {
		padding: 1em 0.5em;
		color: var(--accent);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	@media (max-width: 720px) {
		:global(header .social-links) {
			display: none;
		}
	}
</style>
