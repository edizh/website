---
import { FULL_NAME } from '../consts';
import { sitePath } from '../lib/siteUrl';
import HeaderLink from './HeaderLink.astro';
import SocialLinks from './SocialLinks.astro';
---

<header>
	<nav data-nav>
		<h2><a href={sitePath(Astro.site, '')}>{FULL_NAME}</a></h2>
		<div class="internal-links" id="nav-menu">
			<HeaderLink href={sitePath(Astro.site, '')}>Home</HeaderLink>
			<HeaderLink href={sitePath(Astro.site, 'blog/')}>Blog</HeaderLink>
			<HeaderLink href={sitePath(Astro.site, 'course/')}>Course</HeaderLink>
			<HeaderLink href={sitePath(Astro.site, 'resume/')}>Resume</HeaderLink>
		</div>
		<!-- Wrapper so mobile `display: none` wins over scoped `display: flex` on `.social-links` in SocialLinks.astro. -->
		<div class="header-social">
			<SocialLinks />
		</div>
		<button
			type="button"
			class="nav-toggle"
			aria-expanded="false"
			aria-controls="nav-menu"
			aria-label="Open navigation menu"
		>
			<span class="nav-toggle-bars" aria-hidden="true"></span>
		</button>
	</nav>
</header>
<script>
	function setupNav() {
		const nav = document.querySelector<HTMLElement>('[data-nav]');
		const btn = nav?.querySelector<HTMLButtonElement>('.nav-toggle');
		const menu = document.getElementById('nav-menu');
		if (!nav || !btn || !menu) return;

		function setOpen(open: boolean) {
			nav.classList.toggle('is-open', open);
			btn.setAttribute('aria-expanded', String(open));
			btn.setAttribute('aria-label', open ? 'Close navigation menu' : 'Open navigation menu');
		}

		btn.addEventListener('click', () => setOpen(!nav.classList.contains('is-open')));

		menu.querySelectorAll('a').forEach((a) => {
			a.addEventListener('click', () => setOpen(false));
		});

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape') setOpen(false);
		});
	}

	setupNav();
</script>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
		min-width: 0;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
	}
	h2 a {
		display: block;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		flex-wrap: wrap;
		gap: 0;
	}
	/* Nav link colors: src/styles/global.css (header nav[data-nav] …) so child components + page order never change them. */
	/* Social links live in <SocialLinks />; scope requires :global so `nav a` rules still apply. */
	:global(nav .social-links a) {
		padding: 1em 0.5em;
		color: var(--accent);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	.nav-toggle {
		display: none;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		width: 2.75rem;
		height: 2.75rem;
		margin: 0;
		padding: 0;
		border: none;
		background: transparent;
		cursor: pointer;
		border-radius: 6px;
	}
	.nav-toggle:focus-visible {
		outline: 2px solid var(--accent);
		outline-offset: 2px;
	}
	.nav-toggle-bars {
		position: relative;
		display: block;
		width: 1.35rem;
		height: 2px;
		background: currentColor;
		border-radius: 1px;
		box-shadow:
			0 -6px 0 currentColor,
			0 6px 0 currentColor;
		transition:
			box-shadow 0.2s ease,
			background 0.2s ease;
	}
	nav.is-open .nav-toggle-bars {
		background: transparent;
		box-shadow: none;
	}
	nav.is-open .nav-toggle-bars::before,
	nav.is-open .nav-toggle-bars::after {
		content: '';
		position: absolute;
		left: 0;
		top: 50%;
		width: 100%;
		height: 2px;
		margin-top: -1px;
		background: currentColor;
		border-radius: 1px;
		transition: transform 0.2s ease;
	}
	nav.is-open .nav-toggle-bars::before {
		transform: rotate(45deg);
	}
	nav.is-open .nav-toggle-bars::after {
		transform: rotate(-45deg);
	}

	@media (max-width: 720px) {
		.header-social {
			display: none;
		}
		.nav-toggle {
			display: flex;
			order: 2;
			margin-left: auto;
		}
		h2 {
			order: 1;
			flex: 1;
			min-width: 0;
		}
		.internal-links {
			display: none;
			order: 3;
			flex: 1 1 100%;
			width: 100%;
			flex-direction: column;
			align-items: stretch;
			padding: 0.25em 0 0.75em;
			margin: 0;
			border-top: 1px solid rgba(var(--gray), 22%);
		}
		nav.is-open .internal-links {
			display: flex;
		}
	}

	@media (min-width: 721px) {
		.nav-toggle {
			display: none !important;
		}
	}
</style>
