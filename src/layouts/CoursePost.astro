---
import 'katex/dist/katex.min.css';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
type Props = CollectionEntry<'course'>['data'];

const { title, description, pubDate, updatedDate } = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead description={description} />
		<style>
			main {
				width: calc(100% - 2em);
				max-width: 100%;
				margin: 0;
			}
			.prose {
				width: 720px;
				max-width: calc(100% - 2em);
				margin: auto;
				padding: 1em;
				color: rgb(var(--gray-dark));
			}
			.title {
				margin-bottom: 1em;
				padding: 1em 0;
				text-align: left;
				line-height: 1;
			}
			.title h1 {
				margin: 0 0 0 0;
				font-size: 2.15em;
				line-height: 1.2;
			}
			.subtitle {
				margin: 0 0 0.75rem;
				max-width: 36em;
				font-size: 1.1em;
				font-weight: 400;
				line-height: 1.45;
				color: rgb(var(--gray));
			}
			/* Smaller section headings in posts only (keeps global h1–h3 for other pages). */
			.prose :global(h2) {
				font-size: 1.65em;
			}
			.prose :global(h3) {
				font-size: 1.3em;
			}
			.prose :global(h4) {
				font-size: 1.1em;
			}
			.date {
				margin-bottom: 0.5em;
				color: rgb(var(--gray));
			}
			.last-updated-on {
				font-style: italic;
			}
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<div class="prose">
					<div class="title">
						<div class="date">
							<FormattedDate date={pubDate} />
							{
								updatedDate && (
									<div class="last-updated-on">
										Last updated on <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title}</h1>
						<p class="subtitle">{description}</p>
						<hr />
					</div>
					<slot />
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>
