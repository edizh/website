---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { FULL_NAME } from '../consts';

type Props = CollectionEntry<'resume'>['data'];

const {
	description,
	tagline,
	updatedDate,
	contact,
	summary,
	experience,
	education,
	awards,
	languages,
	skills,
} = Astro.props;
---

<html lang="en">
	<head>
		<BaseHead description={description} />
		<style>
			main.resume {
				box-sizing: border-box;
				width: 100%;
				max-width: min(42rem, 100%);
			}
			main.resume article {
				overflow-x: hidden;
			}
			.resume-header {
				margin-bottom: 2rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.resume-header h1 {
				margin: 0 0 0.35rem;
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.tagline {
				margin: 0 0 0.75rem;
				font-size: 1.05rem;
				line-height: 1.5;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.meta {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.contact {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1.25rem;
				margin: 1rem 0 0;
				padding: 0;
				list-style: none;
				font-size: 0.95rem;
			}
			.contact a {
				text-decoration: none;
				border-bottom: 1px solid rgba(var(--gray), 35%);
			}
			.contact a:hover {
				border-bottom-color: var(--accent);
			}
			.summary {
				margin: 0 0 2rem;
				font-size: 1rem;
				line-height: 1.65;
				color: rgb(var(--gray-dark));
			}
			section {
				margin-bottom: 2rem;
			}
			section h2 {
				margin: 0 0 1rem;
				padding-left: 0.65rem;
				border-left: 3px solid var(--accent);
				font-size: 1.2rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: rgb(var(--black));
			}
			.item {
				margin-bottom: 1.35rem;
			}
			.item:last-child {
				margin-bottom: 0;
			}
			.item-head {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.35rem 1rem;
				margin-bottom: 0.35rem;
			}
			.item-title {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.item-org {
				margin: 0;
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
			}
			/* Middots / separators — accent (org line, tagline, skills, languages). */
			.accent-sep {
				margin: 0 0.35em;
				color: var(--accent);
				font-weight: 700;
			}
			.item-dates {
				margin: 0;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.item-meta {
				margin: 0 0 0.5rem;
				font-size: 0.88rem;
				color: rgb(var(--gray));
			}
			.item ul {
				margin: 0.35rem 0 0;
				padding-left: 1.2rem;
			}
			.item li {
				margin-bottom: 0.35rem;
				font-size: 0.95rem;
				line-height: 1.55;
			}
			.skills {
				margin: 0;
				padding: 0;
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 0.75rem;
				font-size: 0.95rem;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
			}
			.skills li:not(:last-child)::after {
				content: '·';
				margin-left: 0.75rem;
				color: var(--accent);
				font-weight: 700;
			}
			.awards-list {
				margin: 0;
				padding-left: 1.2rem;
				font-size: 0.95rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
			}
			.awards-list li {
				margin-bottom: 0.35rem;
			}
			.languages {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
			}
			@media (max-width: 640px) {
				main.resume {
					padding-left: max(0.75rem, env(safe-area-inset-left));
					padding-right: max(0.75rem, env(safe-area-inset-right));
				}
				.resume-header {
					margin-bottom: 1.65rem;
					padding-bottom: 1.1rem;
				}
				.resume-header h1 {
					font-size: clamp(1.45rem, 5vw, 1.85rem);
					line-height: 1.2;
					overflow-wrap: anywhere;
				}
				.tagline {
					font-size: 1rem;
					line-height: 1.45;
					overflow-wrap: anywhere;
				}
				.meta {
					overflow-wrap: anywhere;
				}
				.contact {
					row-gap: 0.65rem;
					column-gap: 1rem;
				}
				.contact a {
					display: inline-block;
					padding: 0.2rem 0;
				}
				.summary {
					hyphens: auto;
					overflow-wrap: break-word;
				}
				section {
					margin-bottom: 1.65rem;
				}
				section h2 {
					font-size: 1.05rem;
					margin-bottom: 0.85rem;
				}
				.item-head {
					flex-direction: column;
					align-items: flex-start;
					gap: 0.3rem 0;
				}
				.item-dates {
					white-space: normal;
					align-self: flex-start;
					width: 100%;
				}
				.item-org {
					overflow-wrap: anywhere;
				}
				.item-title {
					font-size: 1rem;
					overflow-wrap: anywhere;
				}
				.item li,
				.item-meta {
					font-size: 0.92rem;
				}
				.skills {
					font-size: 0.9rem;
					gap: 0.4rem 0.55rem;
					line-height: 1.45;
				}
				.awards-list,
				.languages {
					font-size: 0.92rem;
					overflow-wrap: anywhere;
				}
			}
			@media print {
				body {
					background: #fff;
				}
				main.resume {
					max-width: 100%;
					padding: 0;
				}
				:global(header),
				:global(footer) {
					display: none;
				}
				.contact a {
					color: inherit;
					border: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="resume">
			<article>
				<header class="resume-header">
					<h1>{FULL_NAME}</h1>
					{tagline && <p class="tagline">{tagline}</p>}
					{
						updatedDate && (
							<p class="meta">
								Updated <FormattedDate date={updatedDate} />
							</p>
						)
					}
					{
						contact && contact.length > 0 && (
							<ul class="contact">
								{contact.map((c) => (
									<li>
										{c.href ? (
											<a href={c.href}>{c.text}</a>
										) : (
											<span>{c.text}</span>
										)}
									</li>
								))}
							</ul>
						)
					}
				</header>

				{summary && <p class="summary">{summary}</p>}

				{
					experience.length > 0 && (
						<section aria-labelledby="exp-heading">
							<h2 id="exp-heading">Experience</h2>
							{experience.map((job) => (
								<div class="item">
									<div class="item-head">
										<div>
											<p class="item-title">{job.role}</p>
											<p class="item-org">
												{job.organization}
												{job.organizationDetail && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{job.organizationDetail}
													</>
												)}
												{job.location && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{job.location}
													</>
												)}
											</p>
										</div>
										<p class="item-dates">{job.dates}</p>
									</div>
									{job.highlights && job.highlights.length > 0 && (
										<ul>
											{job.highlights.map((h) => (
												<li>{h}</li>
											))}
										</ul>
									)}
								</div>
							))}
						</section>
					)
				}

				{
					education && education.length > 0 && (
						<section aria-labelledby="edu-heading">
							<h2 id="edu-heading">Education</h2>
							{education.map((edu) => (
								<div class="item">
									<div class="item-head">
										<div>
											<p class="item-title">{edu.degree}</p>
											<p class="item-org">
												{edu.institution}
												{edu.institutionDetail && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{edu.institutionDetail}
													</>
												)}
											</p>
										</div>
										{edu.dates && <p class="item-dates">{edu.dates}</p>}
									</div>
									{edu.note && <p class="item-meta">{edu.note}</p>}
								</div>
							))}
						</section>
					)
				}

				{
					awards && awards.length > 0 && (
						<section aria-labelledby="awards-heading">
							<h2 id="awards-heading">Awards</h2>
							<ul class="awards-list">
								{awards.map((a) => (
									<li>{a}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					skills && skills.length > 0 && (
						<section aria-labelledby="skills-heading">
							<h2 id="skills-heading">Skills</h2>
							<ul class="skills">
								{skills.map((s) => (
									<li>{s}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					languages && (
						<section aria-labelledby="lang-heading">
							<h2 id="lang-heading">Languages</h2>
							<p class="languages">
								{languages.split(';').map((part, i) => (
									<>
										{i > 0 && (
											<span class="accent-sep" aria-hidden="true">
												·
											</span>
										)}
										{part.trim()}
									</>
								))}
							</p>
						</section>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>
