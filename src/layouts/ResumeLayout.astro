---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { FULL_NAME } from '../consts';
import profileImage from '../assets/profile.jpg';

type Props = CollectionEntry<'resume'>['data'];

const {
	title,
	description,
	tagline,
	updatedDate,
	contact,
	summary,
	experience,
	education,
	awards,
	languages,
	skills,
} = Astro.props;

const pageTitle = `${FULL_NAME} — ${title}`;
---

<html lang="en">
	<head>
		<BaseHead title={pageTitle} description={description} />
		<style>
			main.resume {
				max-width: 42rem;
			}
			.resume-header {
				display: flex;
				flex-direction: row;
				align-items: stretch;
				gap: 1rem 2rem;
				margin-bottom: 2rem;
				padding-bottom: 1.25rem;
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			.resume-header-text {
				flex: 1 1 0;
				min-width: 0;
			}
			.resume-header-photo {
				flex: 0 0 auto;
				align-self: stretch;
				aspect-ratio: 1;
				width: auto;
				max-width: min(12rem, 38vw);
				min-width: 0;
				overflow: hidden;
			}
			.resume-header-photo :global(img) {
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center top;
				display: block;
				border-radius: 0;
			}
			.resume-header h1 {
				margin: 0 0 0.35rem;
				font-size: 2rem;
				font-weight: 700;
				letter-spacing: -0.02em;
			}
			.tagline {
				margin: 0 0 0.75rem;
				font-size: 1.05rem;
				line-height: 1.5;
				color: rgb(var(--gray));
				font-weight: 400;
			}
			.meta {
				margin: 0;
				font-size: 0.9rem;
				color: rgb(var(--gray));
			}
			.contact {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 1.25rem;
				margin: 1rem 0 0;
				padding: 0;
				list-style: none;
				font-size: 0.95rem;
			}
			@media (max-width: 540px) {
				.resume-header {
					flex-direction: column;
					align-items: stretch;
				}
				.resume-header-photo {
					order: -1;
					align-self: center;
					width: min(11rem, 72vw);
					max-width: none;
					aspect-ratio: 1;
				}
			}
			.contact a {
				text-decoration: none;
				border-bottom: 1px solid rgba(var(--gray), 35%);
			}
			.contact a:hover {
				border-bottom-color: var(--accent);
			}
			.summary {
				margin: 0 0 2rem;
				font-size: 1rem;
				line-height: 1.65;
				color: rgb(var(--gray-dark));
			}
			section {
				margin-bottom: 2rem;
			}
			section h2 {
				margin: 0 0 1rem;
				padding-left: 0.65rem;
				border-left: 3px solid var(--accent);
				font-size: 1.2rem;
				font-weight: 700;
				letter-spacing: 0.06em;
				text-transform: uppercase;
				color: rgb(var(--black));
			}
			.item {
				margin-bottom: 1.35rem;
			}
			.item:last-child {
				margin-bottom: 0;
			}
			.item-head {
				display: flex;
				flex-wrap: wrap;
				align-items: baseline;
				justify-content: space-between;
				gap: 0.35rem 1rem;
				margin-bottom: 0.35rem;
			}
			.item-title {
				margin: 0;
				font-size: 1.05rem;
				font-weight: 600;
				color: rgb(var(--black));
			}
			.item-org {
				margin: 0;
				font-size: 0.95rem;
				color: rgb(var(--gray-dark));
			}
			/* Middots / separators — accent (org line, tagline, skills, languages). */
			.accent-sep {
				margin: 0 0.35em;
				color: var(--accent);
				font-weight: 700;
			}
			.item-dates {
				margin: 0;
				font-size: 0.88rem;
				color: rgb(var(--gray));
				white-space: nowrap;
			}
			.item-meta {
				margin: 0 0 0.5rem;
				font-size: 0.88rem;
				color: rgb(var(--gray));
			}
			.item ul {
				margin: 0.35rem 0 0;
				padding-left: 1.2rem;
			}
			.item li {
				margin-bottom: 0.35rem;
				font-size: 0.95rem;
				line-height: 1.55;
			}
			.skills {
				margin: 0;
				padding: 0;
				list-style: none;
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem 0.75rem;
				font-size: 0.95rem;
				line-height: 1.5;
				color: rgb(var(--gray-dark));
			}
			.skills li:not(:last-child)::after {
				content: '·';
				margin-left: 0.75rem;
				color: var(--accent);
				font-weight: 700;
			}
			.awards-list {
				margin: 0;
				padding-left: 1.2rem;
				font-size: 0.95rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
			}
			.awards-list li {
				margin-bottom: 0.35rem;
			}
			.languages {
				margin: 0;
				font-size: 0.95rem;
				line-height: 1.55;
				color: rgb(var(--gray-dark));
			}
			@media print {
				body {
					background: #fff;
				}
				main.resume {
					max-width: 100%;
					padding: 0;
				}
				:global(header),
				:global(footer) {
					display: none;
				}
				.contact a {
					color: inherit;
					border: none;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<main class="resume">
			<article>
				<header class="resume-header">
					<div class="resume-header-text">
						<h1>{FULL_NAME}</h1>
						{tagline && <p class="tagline">{tagline}</p>}
						{
							updatedDate && (
								<p class="meta">
									Updated <FormattedDate date={updatedDate} />
								</p>
							)
						}
						{
							contact && contact.length > 0 && (
								<ul class="contact">
									{contact.map((c) => (
										<li>
											{c.href ? (
												<a href={c.href}>{c.text}</a>
											) : (
												<span>{c.text}</span>
											)}
										</li>
									))}
								</ul>
							)
						}
					</div>
					<div class="resume-header-photo">
						<Image
							src={profileImage}
							alt={`Portrait of ${FULL_NAME}`}
							width={480}
							height={480}
							densities={[1, 2]}
							loading="eager"
							fetchpriority="high"
						/>
					</div>
				</header>

				{summary && <p class="summary">{summary}</p>}

				{
					experience.length > 0 && (
						<section aria-labelledby="exp-heading">
							<h2 id="exp-heading">Experience</h2>
							{experience.map((job) => (
								<div class="item">
									<div class="item-head">
										<div>
											<p class="item-title">{job.role}</p>
											<p class="item-org">
												{job.organization}
												{job.organizationDetail && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{job.organizationDetail}
													</>
												)}
												{job.location && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{job.location}
													</>
												)}
											</p>
										</div>
										<p class="item-dates">{job.dates}</p>
									</div>
									{job.highlights && job.highlights.length > 0 && (
										<ul>
											{job.highlights.map((h) => (
												<li>{h}</li>
											))}
										</ul>
									)}
								</div>
							))}
						</section>
					)
				}

				{
					education && education.length > 0 && (
						<section aria-labelledby="edu-heading">
							<h2 id="edu-heading">Education</h2>
							{education.map((edu) => (
								<div class="item">
									<div class="item-head">
										<div>
											<p class="item-title">{edu.degree}</p>
											<p class="item-org">
												{edu.institution}
												{edu.institutionDetail && (
													<>
														<span class="accent-sep" aria-hidden="true">
															·
														</span>
														{edu.institutionDetail}
													</>
												)}
											</p>
										</div>
										{edu.dates && <p class="item-dates">{edu.dates}</p>}
									</div>
									{edu.note && <p class="item-meta">{edu.note}</p>}
								</div>
							))}
						</section>
					)
				}

				{
					awards && awards.length > 0 && (
						<section aria-labelledby="awards-heading">
							<h2 id="awards-heading">Awards</h2>
							<ul class="awards-list">
								{awards.map((a) => (
									<li>{a}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					skills && skills.length > 0 && (
						<section aria-labelledby="skills-heading">
							<h2 id="skills-heading">Skills</h2>
							<ul class="skills">
								{skills.map((s) => (
									<li>{s}</li>
								))}
							</ul>
						</section>
					)
				}

				{
					languages && (
						<section aria-labelledby="lang-heading">
							<h2 id="lang-heading">Languages</h2>
							<p class="languages">
								{languages.split(';').map((part, i) => (
									<>
										{i > 0 && (
											<span class="accent-sep" aria-hidden="true">
												·
											</span>
										)}
										{part.trim()}
									</>
								))}
							</p>
						</section>
					)
				}
			</article>
		</main>
		<Footer />
	</body>
</html>
